# Police-vs-Thief secrets placeholders. Copy to .env and fill in. NEVER commit .env.
#
# Auth model: agents use the Claude CLI *browser login* (run `claude` once to log in).
# No API key is needed or wanted -- ANTHROPIC_API_KEY is deliberately STRIPPED before
# invoking `claude -p` so the CLI uses your subscription login, not API-key billing.
# Leave ANTHROPIC_API_KEY unset/empty here.
ANTHROPIC_API_KEY=

# Gmail report is sent via the global gg:email skill, which manages its own OAuth token.
# No secret is stored in this project.
